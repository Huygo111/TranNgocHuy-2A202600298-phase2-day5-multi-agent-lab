# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Optional search provider
TAVILY_API_KEY=

# Optional bonus critic
ENABLE_CRITIC=false
CRITIC_QUALITY_THRESHOLD=8.0

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
